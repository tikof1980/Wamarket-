.modal-content h2 { color:var(--vert-fonce); margin-bottom:20px; }
.modal-content label { display:block; font-weight:bold; color:var(--vert-fonce); margin-top:12px; font-size:14px; }
.modal-content input, .modal-content select, .modal-content textarea {
