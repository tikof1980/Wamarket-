}
body { background: linear-gradient(135deg,#E8F5E9 0%,#E3F2FD 50%,#FFEBEE 100%); min-height:100vh; }
.header {
    background: linear-gradient(90deg,var(--vert) 0%,var(--bleu) 70%,var(--rouge) 100%);
    color:white; padding:15px 25px; display:flex; justify-content:space-between;
