    text-align:center; background:#E3F2FD; cursor:pointer; margin:10px 0; transition:all 0.3s;
}
.upload-zone:hover { background:#BBDEFB; }
.upload-zone.has-image { border-color:var(--vert); background:#E8F5E9; }
.upload-zone .upload-icon { font-size:45px; margin-bottom:8px; }
.upload-zone p { color:#1976D2; font-weight:bold; font-size:15px; }
#previewImg {
    width:100%; max-height:200px; object-fit:cover;
    border-radius:10px; margin-top:10px; border:3px solid var(--vert); display:none;
}
.progress-bar {
    width:100%; height:8px; background:#ddd; border-radius:4px; margin-top:8px; display:none;
}
.progress-bar .fill { height:100%; background:linear-gradient(90deg,var(--vert),var(--bleu)); width:0%; border-radius:4px; transition:width 0.3s; }
.modal-actions { display:flex; gap:10px; margin-top:20px; }
.notif {
    position:fixed; top:80px; right:20px;
    background:linear-gradient(90deg,var(--vert),var(--vert-clair));
    color:white; padding:15px 25px; border-radius:10px;
    box-shadow:0 5px 20px rgba(0,0,0,0.3); z-index:2000;
    display:none; font-weight:bold; font-size:15px;
}
.empty { text-align:center; padding:50px; color:#888; }
.empty .empty-icon { font-size:70px; margin-bottom:15px; }
.loading {
    position:fixed; top:0; left:0; width:100%; height:100%;
    background:rgba(0,0,0,0.7); z-index:9999; display:flex;
