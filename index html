.prix { color:var(--rouge); font-size:20px; font-weight:bold; margin-bottom:10px; }
.actions { display:flex; gap:8px; }
.btn { flex:1; padding:10px; border:none; border-radius:8px; cursor:pointer; font-weight:bold; font-size:13px; }
.btn-vert { background:var(--vert); color:white; }
.btn-rouge { background:var(--rouge); color:white; }
