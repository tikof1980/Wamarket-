<script>
// ========== INDEXEDDB - STOCKAGE ILLIMITÉ ==========
let db;
let data = { produits:[], ventes:[], dernierId:0 };
let categorieActive = 'Toutes';
let produitVenteId = null;
let photoBase64 = null;

const DEFAUT = [
    {id:1,nom:"Attiéké Poisson",cat:"Plats",prix:2500,emoji:"🐟",photo:null,desc:"Attiéké poisson braisé"},
    {id:2,nom:"Foutou Sauce Graine",cat:"Plats",prix:3000,emoji:"🍲",photo:null,desc:"Foutou sauce graine viande"},
    {id:3,nom:"Riz Sauce Arachide",cat:"Plats",prix:2000,emoji:"🍚",photo:null,desc:"Riz sauce arachide poulet"},
    {id:4,nom:"Kedjenou Poulet",cat:"Plats",prix:3500,emoji:"🍗",photo:null,desc:"Poulet mijoté aux légumes"},
    {id:5,nom:"Garba",cat:"Plats",prix:1500,emoji:"🐟",photo:null,desc:"Attiéké thon frit"},
    {id:6,nom:"Alloco",cat:"Entrées",prix:1000,emoji:"🍌",photo:null,desc:"Banane plantain frite"},
    {id:7,nom:"Brochettes",cat:"Grillades",prix:2000,emoji:"🍢",photo:null,desc:"Brochettes de bœuf"},
    {id:8,nom:"Poulet braisé",cat:"Grillades",prix:4000,emoji:"🔥",photo:null,desc:"Demi poulet braisé"},
    {id:9,nom:"Bissap",cat:"Boissons",prix:500,emoji:"🍷",photo:null,desc:"Jus de bissap frais"},
    {id:10,nom:"Coca-Cola",cat:"Boissons",prix:700,emoji:"🥫",photo:null,desc:"Canette 33cl"},
    {id:11,nom:"Eau minérale",cat:"Eau",prix:300,emoji:"💧",photo:null,desc:"Bouteille 50cl"},
    {id:12,nom:"Salade de fruits",cat:"Désserts",prix:1500,emoji:"🍓",photo:null,desc:"Fruits frais"},
    {id:13,nom:"Café",cat:"Petit-déjeuner",prix:500,emoji:"☕",photo:null,desc:"Café noir ou au lait"},
];

// ===== OUVRIR INDEXEDDB =====
function ouvrirDB() {
    return new Promise((resolve, reject) => {
        const req = indexedDB.open('WamarketDB', 1);

        req.onupgradeneeded = (e) => {
            const db = e.target.result;
            if (!db.objectStoreNames.contains('produits')) {
                db.createObjectStore('produits', { keyPath: 'id' });
            }
            if (!db.objectStoreNames.contains('ventes')) {
                db.createObjectStore('ventes', { keyPath: 'id', autoIncrement: true });
            }
            if (!db.objectStoreNames.contains('config')) {
                db.createObjectStore('config', { keyPath: 'cle' });
            }
        };

        req.onsuccess = (e) => { db = e.target.result; resolve(db); };
        req.onerror = (e) => reject(e);
    });
}

// ===== SAUVEGARDER PRODUIT =====
function sauvegarderProduit(produit) {
    return new Promise((resolve, reject) => {
        const tx = db.transaction('produits', 'readwrite');
        tx.objectStore('produits').put(produit);
        tx.oncomplete = () => resolve();
        tx.onerror = (e) => reject(e);
    });
}

// ===== SUPPRIMER PRODUIT DB =====
function supprimerProduitDB(id) {
    return new Promise((resolve, reject) => {
        const tx = db.transaction('produits', 'readwrite');
        tx.objectStore('produits').delete(id);
        tx.oncomplete = () => resolve();
        tx.onerror = (e) => reject(e);
    });
}

// ===== CHARGER TOUS LES PRODUITS =====
function chargerProduits() {
    return new Promise((resolve, reject) => {
        const tx = db.transaction('produits', 'readonly');
        const req = tx.objectStore('produits').getAll();
        req.onsuccess = () => resolve(req.result);
        req.onerror = (e) => reject(e);
    });
}

// ===== SAUVEGARDER VENTE =====
function sauvegarderVente(vente) {
    return new Promise((resolve, reject) => {
        const tx = db.transaction('ventes', 'readwrite');
        tx.objectStore('ventes').add(vente);
        tx.oncomplete = () => resolve();
        tx.onerror = (e) => reject(e);
    });
}

// ===== CHARGER VENTES =====
function chargerVentes() {
    return new Promise((resolve, reject) => {
        const tx = db.transaction('ventes', 'readonly');
        const req = tx.objectStore('ventes').getAll();
        req.onsuccess = () => resolve(req.result);
        req.onerror = (e) => reject(e);
    });
}

// ===== SAUVEGARDER CONFIG =====
function sauvegarderConfig(cle, valeur) {
    return new Promise((resolve) => {
        const tx = db.transaction('config', 'readwrite');
        tx.objectStore('config').put({ cle, valeur });
        tx.oncomplete = () => resolve();
    });
}

function chargerConfig(cle) {
    return new Promise((resolve) => {
        const tx = db.transaction('config', 'readonly');
        const req = tx.objectStore('config').get(cle);
        req.onsuccess = () => resolve(req.result ? req.result.valeur : null);
        req.onerror = () => resolve(null);
    });
}

// ===== COMPRESSION IMAGE =====
function compresserImage(file) {
    return new Promise((resolve) => {
        const progressBar = document.getElementById('progressBar');
        const progressFill = document.getElementById('progressFill');
        progressBar.style.display = 'block';
        progressFill.style.width = '20%';

        const reader = new FileReader();
        reader.onload = (e) => {
            progressFill.style.width = '50%';
            const img = new Image();
            img.onload = () => {
                progressFill.style.width = '80%';
                const canvas = document.createElement('canvas');
                let w = img.width, h = img.height;
                // Max 800px
                const max = 800;
                if (w > max || h > max) {
                    if (w > h) { h = Math.round(h * max / w); w = max; }
                    else { w = Math.round(w * max / h); h = max; }
                }
                canvas.width = w; canvas.height = h;
                canvas.getContext('2d').drawImage(img, 0, 0, w, h);
                // Qualité 0.7 pour bonne qualité sans trop peser
                const result = canvas.toDataURL('image/jpeg', 0.7);
                progressFill.style.width = '100%';
                setTimeout(() => { progressBar.style.display = 'none'; resolve(result); }, 300);
            };
            img.src = e.target.result;
        };
        reader.readAsDataURL(file);
    });
}

// ===== SON =====
function jouerSon() {
    try {
        const ctx = new (window.AudioContext || window.webkitAudioContext)();
        [880, 1100, 1320].forEach((freq, i) => {
            const osc = ctx.createOscillator();
            const gain = ctx.createGain();
            osc.connect(gain); gain.connect(ctx.destination);
            osc.frequency.value = freq;
            const t = ctx.currentTime + i * 0.15;
            gain.gain.setValueAtTime(0.3, t);
            gain.gain.exponentialRampToValueAtTime(0.01, t + 0.2);
            osc.start(t); osc.stop(t + 0.2);
        });
    } catch(e) {}
}

// ===== NOTIFICATION =====
function notifier(msg, type) {
    const n = document.getElementById('notif');
    n.textContent = msg;
    n.style.background = type === 'rouge' ? 'linear-gradient(90deg,#D32F2F,#B71C1C)' :
        type === 'bleu' ? 'linear-gradient(90deg,#1976D2,#0D47A1)' :
        'linear-gradient(90deg,#1B8E3A,#4CAF50)';
    n.style.display = 'block';
    setTimeout(() => n.style.display = 'none', 3500);
}

// ===== NAVIGATION =====
document.querySelectorAll('.nav button').forEach(btn => {
    btn.addEventListener('click', () => {
        document.querySelectorAll('.nav button').forEach(b => b.classList.remove('active'));
        document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
        btn.classList.add('active');
        document.getElementById(btn.dataset.screen).classList.add('active');
        actualiser();
    });
});

// ===== MODALS =====
function ouvrirModal(id) { document.getElementById(id).classList.add('show'); }
function fermerModal(id) { document.getElementById(id).classList.remove('show'); }

function ouvrirAjout() {
    photoBase64 = null;
    document.getElementById('previewImg').style.display = 'none';
    document.getElementById('previewImg').src = '';
    document.getElementById('nomP').value = '';
    document.getElementById('catP').value = '';
