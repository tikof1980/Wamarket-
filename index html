// ===== UPLOAD PHOTO =====
document.getElementById('uploadZone').addEventListener('click', () => {
    document.getElementById('photoP').click();
});

document.getElementById('photoP').addEventListener('change', async function(e) {
    const file = e.target.files[0];
    if (!file) return;
    if (!file.type.startsWith('image/')) {
        notifier('⚠️ Choisissez une image !', 'rouge');
        return;
    }
    notifier('🔄 Traitement en cours...', 'bleu');
    const compressed = await compresserImage(file);
    photoBase64 = compressed;

    const preview = document.getElementById('previewImg');
    preview.src = compressed;
    preview.style.display = 'block';

    const zone = document.getElementById('uploadZone');
    zone.className = 'upload-zone has-image';
    zone.innerHTML = '<div class="upload-icon">✅</div><p style="color:#1B8E3A">Photo chargée !</p><small>Appuyer pour changer</small>';
    notifier('✅ Photo prête !');
});

// ===== AJOUTER PRODUIT =====
document.getElementById('btnValider').addEventListener('click', async function() {
    const nom = document.getElementById('nomP').value.trim();
    const cat = document.getElementById('catP').value;
    const prix = parseInt(document.getElementById('prixP').value);
    const emoji = document.getElementById('emojiP').value.trim() || '🍴';
    const desc = document.getElementById('descP').value.trim();

    if (!nom) { notifier('⚠️ Entrez le nom du plat !', 'rouge'); return; }
    if (!cat) { notifier('⚠️ Choisissez une catégorie !', 'rouge'); return; }
    if (!prix || prix < 1) { notifier('⚠️ Entrez un prix valide !', 'rouge'); return; }

    data.dernierId++;
    await sauvegarderConfig('dernierId', data.dernierId);

    const produit = {
        id: data.dernierId,
        nom, cat, prix, emoji,
        photo: photoBase64 || null,
        desc: desc || 'Délicieux plat'
    };

    try {
        await sauvegarderProduit(produit);
        data.produits.push(produit);
        jouerSon();
        notifier('✅ "' + nom + '" ajouté avec succès !');
        fermerModal('modalAjout');
        actualiser();
    } catch(e) {
        notifier('⚠️ Erreur lors de l\'ajout', 'rouge');
        console.error(e);
    }
});

document.getElementById('btnAnnuler').addEventListener('click', () => fermerModal('modalAjout'));
document.getElementById('btnAddMenu').addEventListener('click', ouvrirAjout);
document.getElementById('btnAddGalerie').addEventListener('click', ouvrirAjout);

// ===== SUPPRIMER =====
async function supprimerProduit(id) {
    const p = data.produits.find(x => x.id === id);
    if (!p) return;
    if (confirm('❌ Supprimer "' + p.nom + '" ?\n\nCette action est irréversible !')) {
        try {
            await supprimerProduitDB(id);
            data.produits = data.produits.filter(x => x.id !== id);
            notifier('🗑️ "' + p.nom + '" supprimé', 'rouge');
            actualiser();
        } catch(e) {
            notifier('⚠️ Erreur suppression', 'rouge');
        }
    }
}

// ===== VENTE =====
function ouvrirVente(id) {
    produitVenteId = id;
    const p = data.produits.find(x => x.id === id);
    if (!p) return;
    document.getElementById('infoVente').innerHTML =
        '<div style="padding:15px;background:#E8F5E9;border-radius:8px;margin-bottom:10px">' +
        '<strong>' + (p.emoji||'🍴') + ' ' + p.nom + '</strong><br>' +
        '<span style="color:#D32F2F;font-size:20px;font-weight:bold">' + p.prix.toLocaleString() + ' FCFA</span></div>';
    document.getElementById('qteV').value = 1;
    document.getElementById('tableV').value = '';
    ouvrirModal('modalVente');
}

document.getElementById('btnValiderVente').addEventListener('click', async function() {
    const qte = parseInt(document.getElementById('qteV').value);
    const table = document.getElementById('tableV').value.trim() || 'Comptoir';
    const p = data.produits.find(x => x.id === produitVenteId);
    if (!p || !qte || qte < 1) { notifier('⚠️ Quantité invalide', 'rouge'); return; }
    const vente = {
        produit: p.nom, emoji: p.emoji||'🍴', qte,
        total: qte * p.prix, table,
        heure: new Date().toLocaleTimeString('fr-FR',{hour:'2-digit',minute:'2-digit'}),
        date: new Date().toLocaleDateString('fr-FR')
    };
    try {
        await sauvegarderVente(vente);
        data.ventes.push(vente);
        jouerSon();
        notifier('💰 Vente : ' + vente.total.toLocaleString() + ' FCFA', 'bleu');
        fermerModal('modalVente');
        actualiser();
    } catch(e) {
        notifier('⚠️ Erreur vente', 'rouge');
    }
});

document.getElementById('btnAnnulerVente').addEventListener('click', () => fermerModal('modalVente'));

document.querySelectorAll('.modal').forEach(m => {
    m.addEventListener('click', e => { if (e.target === m) m.classList.remove('show'); });
});

// ===== CRÉER CARTE =====
function creerCarte(p) {
    const d = document.createElement('div');
    d.className = 'produit-card';

    const imgZone = p.photo
        ? '<img src="' + p.photo + '" alt="' + p.nom + '">'
        : (p.emoji || '🍴');

    d.innerHTML =
        '<div class="produit-img">' + imgZone + '</div>' +
        '<div class="produit-info">' +
            '<h3>' + p.nom + '</h3>' +
            '<span class="cat-tag">' + p.cat + '</span>' +
            '<p class="desc">' + (p.desc||'') + '</p>' +
            '<div class="prix">' + p.prix.toLocaleString() + ' FCFA</div>' +
            '<div class="actions">' +
                '<button class="btn btn-vert" data-id="' + p.id + '" data-action="vendre">🛒 Vendre</button>' +
                '<button class="btn btn-rouge" data-id="' + p.id + '" data-action="supprimer">🗑️ Suppr.</button>' +
            '</div>' +
        '</div>';

    d.querySelectorAll('button[data-action]').forEach(btn => {
        btn.addEventListener('click', () => {
            const id = parseInt(btn.dataset.id);
            if (btn.dataset.action === 'vendre') ouvrirVente(id);
            else supprimerProduit(id);
        });
    });

    return d;
}

// ===== ACTUALISER =====
function actualiser() {
    const cats = [...new Set(data.produits.map(p => p.cat))];
    const today = new Date().toLocaleDateString('fr-FR');
    const ventesAuj = data.ventes.filter(v => v.date === today);
    const recette = ventesAuj.reduce((s,v) => s+v.total, 0);

    document.getElementById('sProduits').textContent = data.produits.length;
    document.getElementById('sCats').textContent = cats.length;
    document.getElementById('sRecette').textContent = recette.toLocaleString() + ' F';
    document.getElementById('sVentes').textContent = ventesAuj.length;

    // Accueil
    const ga = document.getElementById('gridAccueil');
    ga.innerHTML = '';
    data.produits.slice(0,8).forEach(p => ga.appendChild(creerCarte(p)));

    // Menu
    const cb = document.getElementById('catsBar');
    cb.innerHTML = '';
    const btnAll = document.createElement('button');
    btnAll.className = 'cat-btn' + (categorieActive==='Toutes' ? ' active' : '');
    btnAll.textContent = '📋 Toutes (' + data.produits.length + ')';
    btnAll.addEventListener('click', () => { categorieActive='Toutes'; actualiser(); });
    cb.appendChild(btnAll);
    cats.forEach(c => {
        const n = data.produits.filter(p=>p.cat===c).length;
        const b = document.createElement('button');
        b.className = 'cat-btn' + (categorieActive===c ? ' active' : '');
        b.textContent = c + ' (' + n + ')';
        b.addEventListener('click', () => { categorieActive=c; actualiser(); });
        cb.appendChild(b);
    });

    const gm = document.getElementById('gridMenu');
    gm.innerHTML = '';
    const filtres = categorieActive==='Toutes' ? data.produits : data.produits.filter(p=>p.cat===categorieActive);
    if (filtres.length === 0) {
        gm.innerHTML = '<div class="empty"><div class="empty-icon">🍽️</div><p>Aucun plat ici</p></div>';
    } else {
        filtres.forEach(p => gm.appendChild(creerCarte(p)));
    }

    // Galerie
    const gg = document.getElementById('gridGalerie');
    gg.innerHTML = '';
    const ca = document.createElement('div');
    ca.className = 'card-ajouter';
    ca.innerHTML = '<div class="plus">➕</div><h3>Ajouter un plat</h3><p>Appuyer pour ajouter avec photo</p>';
    ca.addEventListener('click', ouvrirAjout);
    gg.appendChild(ca);
    data.produits.forEach(p => gg.appendChild(creerCarte(p)));

    // Caisse
    document.getElementById('totalJour').textContent = recette.toLocaleString() + ' FCFA';
    const lc = document.getElementById('listeCaisse');
    lc.innerHTML = '';
    if (ventesAuj.length === 0) {
        lc.innerHTML = '<div class="empty"><div class="empty-icon">💰</div><p>Aucune vente aujourd\'hui</p></div>';
    } else {
        ventesAuj.slice().reverse().forEach(v => {
            const el = document.createElement('div');
            el.style.cssText = 'background:white;padding:15px;border-radius:10px;margin-bottom:10px;display:flex;justify-content:space-between;align-items:center;border-left:4px solid #1B8E3A;box-shadow:0 2px 8px rgba(0,0,0,0.06)';
            el.innerHTML =
                '<div><strong>' + v.emoji + ' ' + v.produit + '</strong> × ' + v.qte + '<br>' +
                '<small style="color:#666">🪑 ' + v.table + ' • ⏰ ' + v.heure + '</small></div>' +
                '<strong style="color:#1B8E3A;font-size:17px">' + v.total.toLocaleString() + ' F</strong>';
            lc.appendChild(el);
        });
    }

    // Stats
    document.getElementById('statsDetail').innerHTML =
        '<div class="stats-grid">' +
            '<div class="stat-card vert"><div class="icon">📦</div><h3>Produits</h3><div class="value">' + data.produits.length + '</div></div>' +
            '<div class="stat-card bleu"><div class="icon">🧾</div><h3>Ventes totales</h3><div class="value">' + data.ventes.length + '</div></div>' +
            '<div class="stat-card rouge"><div class="icon">💰</div><h3>Recette totale</h3><div class="value">' + data.ventes.reduce((s,v)=>s+v.total,0).toLocaleString() + ' F</div></div>' +
        '</div>' +
        '<h3 style="margin:25px 0 15px;color:#0F5F24">Par catégorie</h3>' +
        cats.map(c => {
            const n = data.produits.filter(p=>p.cat===c).length;
            return '<div style="background:white;padding:12px 18px;border-radius:10px;margin-bottom:8px;display:flex;justify-content:space-between;border-left:4px solid #1976D2"><strong>' + c + '</strong><span>' + n + ' produit(s)</span></div>';
        }).join('');
}

// ===== HORLOGE =====
setInterval(() => {
    document.getElementById('heure').textContent =
        new Date().toLocaleTimeString('fr-FR',{hour:'2-digit',minute:'2-digit'});
}, 1000);
document.getElementById('heure').textContent =
    new Date().toLocaleTimeString('fr-FR',{hour:'2-digit',minute:'2-digit'});

// ===== DÉMARRAGE =====
async function demarrer() {
    try {
        await ouvrirDB();

        // Charger dernierId
        const lastId = await chargerConfig('dernierId');
        data.dernierId = lastId || 13;

        // Charger produits
        const produits = await chargerProduits();
        if (produits.length === 0) {
            // Insérer produits par défaut
            for (const p of DEFAUT) {
                await sauvegarderProduit(p);
            }
            data.produits = [...DEFAUT];
        } else {
            data.produits = produits;
        }

        // Charger ventes
        data.ventes = await chargerVentes();

        document.getElementById('loading').style.display = 'none';
        actualiser();
    } catch(e) {
        console.error('Erreur démarrage:', e);
        document.getElementById('loading').innerHTML =
            '<div style="color:red;text-align:center;padding:20px">❌ Erreur: ' + e.message + '</div>';
    }
}

demarrer();
</script>
