}
.produit-img img { width:100%; height:100%; object-fit:cover; }
.produit-info { padding:15px; }
.produit-info h3 { color:var(--vert-fonce); margin-bottom:5px; font-size:17px; }
.cat-tag { display:inline-block; background:var(--bleu); color:white; padding:3px 10px; border-radius:12px; font-size:11px; margin-bottom:8px; }
